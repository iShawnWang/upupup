# 监控目标，JSON 数组
# 必填字段：name, url
# 可选字段：method（默认 GET）、keyword、expectedStatus（默认 200）、timeout（默认 10000ms）
MONITORS='[
  {
    "name": "乔乔车测试",
    "url": "https://apideve.yeqiao.cn/dev-api/admin/dict/getSysDictTypeNotDelete?dictType=ORDER_STATUS",
    "keyword": "dictType"
  }
]'

# 检测间隔（秒），最小 30
CHECK_INTERVAL_SECONDS=60

# 历史保留天数
HISTORY_RETENTION_DAYS=90

# SQLite 文件路径
DB_PATH=./data/upupup.db
